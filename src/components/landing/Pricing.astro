---
import { getPlanWhatsAppUrl } from '../../utils/whatsapp';

const impulsoUrl = getPlanWhatsAppUrl('impulso');
const crecimientoUrl = getPlanWhatsAppUrl('crecimiento');
const dominioUrl = getPlanWhatsAppUrl('dominio');
---

<section id="pricing" class="pricing-section">
  <div class="container">
    <div class="section-header">
      <span class="pre-title">PAQUETES Y PRECIOS</span>
      <h2 class="section-title">Elige el paquete ideal <br/>para hacer crecer tu negocio</h2>
      <p class="section-desc">Planes claros en pesos mexicanos (MXN) adaptados al nivel de madurez y volumen de leads de tu negocio.</p>
    </div>

    <div class="pricing-grid">
      <!-- Plan 1: Impulso -->
      <div class="pricing-card">
        <div class="plan-header">
          <h3 class="plan-name">Impulso Digital</h3>
          <p class="plan-desc">Ideal para negocios locales que quieren arrancar.</p>
          <div class="plan-price">
            <span class="currency">$</span>
            <span class="amount">2,490</span>
            <span class="period">/ MXN mes</span>
          </div>
        </div>
        <ul class="plan-features">
          <li>1 Chatbot de WhatsApp (Flujo Básico)</li>
          <li>1 Campaña de Publicidad (Meta o Google)</li>
          <li>Landing Page Optimizada</li>
          <li>Reporte Mensual de Conversiones</li>
        </ul>
        <a href={impulsoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary" data-ga-event="cta_click">
          Elegir Impulso Digital
        </a>
      </div>

      <!-- Plan 2: Crecimiento (Popular/Highlighted) -->
      <div class="pricing-card highlighted">
        <div class="popular-tag">MÁS POPULAR</div>
        <div class="plan-header">
          <h3 class="plan-name">Crecimiento Automático</h3>
          <p class="plan-desc">Para empresas que buscan automatizar la calificación de leads.</p>
          <div class="plan-price">
            <span class="currency">$</span>
            <span class="amount">3,790</span>
            <span class="period">/ MXN mes</span>
          </div>
        </div>
        <ul class="plan-features">
          <li>Chatbot Calificador Avanzado (WhatsApp + IG)</li>
          <li>2 Campañas de Publicidad Activas</li>
          <li>Integración Básica con CRM (Google Sheets)</li>
          <li>Landing Page Premium con FAQs</li>
          <li>Soporte Técnico Mensual</li>
        </ul>
        <a href={crecimientoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-ga-event="cta_click">
          Elegir Crecimiento Automático
        </a>
      </div>

      <!-- Plan 3: Dominio 360 -->
      <div class="pricing-card">
        <div class="plan-header">
          <h3 class="plan-name">Dominio 360</h3>
          <p class="plan-desc">Automatización multicanal y estrategia de tráfico completa.</p>
          <div class="plan-price">
            <span class="currency">$</span>
            <span class="amount">5,790</span>
            <span class="period">/ MXN mes</span>
          </div>
        </div>
        <ul class="plan-features">
          <li>Automatización Multi-canal (WA, IG, FB)</li>
          <li>Estrategia Completa Meta + Google Ads</li>
          <li>Integración Completa con tu CRM (Hubspot/Zoho)</li>
          <li>Embudo y Landing Page a Medida</li>
          <li>Soporte Prioritario 24/7</li>
        </ul>
        <a href={dominioUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary" data-ga-event="cta_click">
          Elegir Dominio 360
        </a>
      </div>
    </div>

    <p class="pricing-footer-note">¿Necesitas algo específico? <a href={getPlanWhatsAppUrl('crecimiento')} target="_blank" rel="noopener noreferrer">Contáctanos por WhatsApp</a> y cotizamos una solución a la medida de tu negocio.</p>
  </div>
</section>

<style>
  .pricing-section {
    padding: 6rem 1.5rem;
    background: var(--bg-primary);
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem;
  }

  .pre-title {
    color: var(--accent-secondary);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: stretch;
    margin-bottom: 3.5rem;
  }

  .pricing-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
    position: relative;
  }

  .pricing-card:hover {
    transform: translateY(-5px);
    border-color: rgba(163, 113, 247, 0.25);
    box-shadow: 0 15px 35px rgba(163, 113, 247, 0.08);
  }

  .pricing-card.highlighted {
    border-color: var(--border-highlight);
    background: linear-gradient(180deg, var(--bg-secondary) 0%, rgba(163, 113, 247, 0.04) 100%);
    box-shadow: 0 10px 40px rgba(163, 113, 247, 0.12);
  }

  .popular-tag {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 1rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .plan-header {
    margin-bottom: 2rem;
  }

  .plan-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.5rem;
  }

  .plan-desc {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.4;
    margin-bottom: 1.5rem;
    min-height: 40px;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    color: #ffffff;
  }

  .currency {
    font-size: 1.5rem;
    font-weight: 600;
    margin-right: 0.2rem;
  }

  .amount {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .period {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-left: 0.4rem;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    line-height: 1.4;
  }

  .plan-features li::before {
    content: '✓';
    color: var(--accent-secondary);
    font-weight: bold;
    flex-shrink: 0;
  }

  .btn {
    width: 100%;
    padding: 0.8rem 1.5rem;
    border-radius: 9999px;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent-primary) 0%, rgba(163, 113, 247, 0.8) 100%);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 4px 15px rgba(163, 113, 247, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(163, 113, 247, 0.45);
    color: #ffffff;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.02);
    color: #ffffff;
    border: 1px solid var(--border-subtle);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-2px);
    color: #ffffff;
  }

  .pricing-footer-note {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .pricing-footer-note a {
    color: var(--accent-primary);
    font-weight: 600;
    text-decoration: underline;
  }

  @media (max-width: 992px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .pricing-card {
      padding: 2.5rem 2rem;
    }
  }
</style>
