---
import { getPlanWhatsAppUrl } from '../../utils/whatsapp';

const primaryCta = getPlanWhatsAppUrl('crecimiento');
---

<section class="cta-banner-section">
  <div class="cta-gradient-glow"></div>
  <div class="container">
    <div class="cta-card">
      <h2 class="cta-title">¿Listo para automatizar y <br/>hacer crecer tu negocio?</h2>
      <p class="cta-desc">Chatea con nosotros y configuremos la infraestructura de prospección y ventas definitiva para tu empresa.</p>
      <div class="cta-buttons">
        <a href={primaryCta} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-ga-event="cta_click">
          Comenzar Ahora (Gratis)
        </a>
        <a href="#pricing" class="btn btn-secondary">
          Ver Paquetes
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner-section {
    padding: 6rem 1.5rem;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .cta-card {
    background: linear-gradient(135deg, rgba(22, 22, 30, 0.9) 0%, rgba(13, 13, 18, 0.9) 100%);
    border: 1px solid var(--border-highlight);
    border-radius: 32px;
    padding: 5rem 3rem;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), inset 0 0 30px rgba(163, 113, 247, 0.05);
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 0%, rgba(45, 212, 191, 0.08) 0%, transparent 60%);
    z-index: -1;
  }

  .cta-title {
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .cta-desc {
    color: var(--text-secondary);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    align-items: center;
  }

  .btn {
    padding: 0.9rem 2.25rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 1rem;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent-primary) 0%, rgba(163, 113, 247, 0.8) 100%);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 4px 20px rgba(163, 113, 247, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(163, 113, 247, 0.5);
    color: #ffffff;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.02);
    color: #ffffff;
    border: 1px solid var(--border-subtle);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-2px);
    color: #ffffff;
  }

  .cta-gradient-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 350px;
    background: radial-gradient(circle, rgba(163, 113, 247, 0.08) 0%, rgba(45, 212, 191, 0.03) 60%, transparent 100%);
    z-index: 1;
    filter: blur(50px);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: 4rem 2rem;
      border-radius: 24px;
    }

    .cta-title {
      font-size: 2rem;
    }

    .cta-buttons {
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
    }

    .btn {
      width: 100%;
    }
  }
</style>
