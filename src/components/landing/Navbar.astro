---
import { getWhatsAppUrl } from '../../utils/whatsapp';

const ctaUrl = getWhatsAppUrl("Hola, me interesa obtener más información sobre las automatizaciones y servicios.");
---

<header class="navbar">
  <div class="navbar-container">
    <a href="#" class="logo">
      Ingeniería<span>enCancún</span>
    </a>
    
    <nav class="nav-links">
      <a href="#features" class="nav-item">Automatización</a>
      <a href="#pricing" class="nav-item">Precios</a>
      <a href="#faq" class="nav-item">Preguntas</a>
    </nav>
    
    <div class="nav-actions">
      <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-cta" data-ga-event="cta_click">
        Hablar por WhatsApp
      </a>
      <button class="menu-toggle" aria-label="Abrir menú" id="menuToggle">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12" class="line-mid"></line>
          <line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
          <line x1="3" y1="18" x2="21" y2="18" class="line-bot"></line>
        </svg>
      </button>
    </div>
  </div>
  
  <div class="mobile-menu" id="mobileMenu">
    <nav class="mobile-nav-links">
      <a href="#features" class="mobile-nav-item">Automatización</a>
      <a href="#pricing" class="mobile-nav-item">Precios</a>
      <a href="#faq" class="mobile-nav-item">Preguntas</a>
      <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-cta mobile-cta" data-ga-event="cta_click">
        Hablar por WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('active');
      toggle.classList.toggle('active');
    });
    
    // Close menu when clicking links
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('active');
        toggle.classList.remove('active');
      });
    });
  }
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    width: 100%;
    z-index: 100;
    background: rgba(5, 5, 7, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .navbar-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 101;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    gap: 0.1rem;
  }

  .logo span {
    color: var(--accent-primary);
    background: linear-gradient(135deg, var(--accent-primary) 30%, var(--accent-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-item {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .nav-item:hover {
    color: #ffffff;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .btn-cta {
    background: linear-gradient(135deg, var(--accent-primary) 0%, rgba(163, 113, 247, 0.8) 100%);
    color: #ffffff;
    padding: 0.6rem 1.2rem;
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 4px 15px rgba(163, 113, 247, 0.2);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(163, 113, 247, 0.4);
    color: #ffffff;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 0.5rem;
  }

  .menu-toggle svg {
    transition: transform var(--transition-normal);
  }

  .menu-toggle.active svg {
    transform: rotate(90deg);
  }

  /* Mobile menu styles */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: rgba(5, 5, 7, 0.98);
    border-bottom: 1px solid var(--border-subtle);
    padding: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal) ease-out, padding var(--transition-normal) ease-out;
    backdrop-filter: blur(20px);
  }

  .mobile-menu.active {
    max-height: 300px;
    padding: 1.5rem;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
  }

  .mobile-nav-item {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .mobile-cta {
    width: 100%;
    text-align: center;
    padding: 0.8rem;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    
    .nav-actions .btn-cta {
      display: none;
    }

    .menu-toggle {
      display: block;
    }
  }
</style>
