---
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <SEO title={title} description={description} />
  <body>
    <!-- GA4 Tracking -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');

      document.addEventListener('click', function(e) {
        const target = e.target.closest('[data-ga-event="cta_click"]');
        if (target) {
          gtag('event', 'cta_click', {
            event_category: 'engagement',
            event_label: 'WhatsApp CTA',
          });
        }
      });
    </script>
    
    <div class="glow-effect"></div>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  .glow-effect {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: -1;
    background: 
      radial-gradient(circle at 15% 50%, rgba(163, 113, 247, 0.04), transparent 25%),
      radial-gradient(circle at 85% 30%, rgba(45, 212, 191, 0.04), transparent 25%);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    width: 100%;
  }
</style>
