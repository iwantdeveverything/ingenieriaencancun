---
import Layout from '../../layouts/Layout.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';

const title = "Local SEO | Ingeniería en Cancún";
const description = "Dominate local search results and drive foot traffic in Cancún and beyond.";
---

<Layout title={title} description={description}>
  <div class="service-header">
    <h1>Local SEO</h1>
    <p class="subtitle">Dominate local search results and drive foot traffic in Cancún and beyond.</p>
  </div>
  
  <div class="service-content">
    <div class="deliverables">
      <h2>Key Deliverables</h2>
      <ul>
        <li>Google Business Profile Optimization</li>
        <li>Local Citation Building & Management</li>
        <li>Location-Specific Content Strategy</li>
        <li>Local Link Building Campaigns</li>
      </ul>
    </div>
    
    <div class="cta-container">
      <WhatsAppCTA inline={true} message="Hi, I'm interested in Local SEO for my business." text="Start Dominating Locally" />
    </div>
  </div>
  <WhatsAppCTA />
</Layout>

<style>
  .service-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  
  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(to right, #fff, var(--text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: var(--space-md);
  }
  
  .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .service-content {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: var(--space-xl);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .deliverables h2 {
    color: var(--accent-primary);
    font-size: 1.5rem;
    margin-bottom: var(--space-lg);
  }

  .deliverables ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  .deliverables li {
    position: relative;
    padding-left: 2rem;
    color: var(--text-primary);
    font-size: 1.1rem;
  }

  .deliverables li::before {
    content: "✦";
    position: absolute;
    left: 0;
    color: var(--accent-secondary);
  }

  .cta-container {
    margin-top: var(--space-xl);
    text-align: center;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-subtle);
  }
</style>
